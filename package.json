{
  "name": "library-system-api",
  "version": "1.0.0",
  "main": "index.js",
  "license": "ISC",
  "scripts": {
    "dev": "tsx watch --inspect src/shared/infra/http/main.ts",
    "format": "prettier --write 'src/**/*.{ts,js,json}'",
    "build": "tsc && tsc-alias",
    "lint": "eslint --config eslint.config.mjs 'src/**/*.{ts,js}'",
    "lint-fix": "eslint --fix --config eslint.config.mjs 'src/**/*.{ts,js}'",
    "typeorm": "tsx ./node_modules/typeorm/cli.js",
    "migration:create": "tsx ./node_modules/typeorm/cli.js migration:create",
    "migration:run:dev": "tsx ./node_modules/typeorm/cli.js migration:run -d ./src/shared/infra/typeorm/dataSource.ts",
    "migration:run:prod": "cross-env NODE_ENV=production DOTENV_CONFIG_PATH=.env.production node --require dotenv/config ./node_modules/typeorm/cli.js migration:run -d dist/shared/infra/typeorm/dataSource.js",
    "prod": "cross-env NODE_ENV=production node -r module-alias/register -r tsconfig-paths/register dist/shared/infra/http/app.js"
  },
  "_moduleAliases": {
    "@config": "./dist/config",
    "@modules": "./dist/modules",
    "@shared": "./dist/shared",
    "@helpers": "./dist/helpers"
  },
  "devDependencies": {
    "@eslint/create-config": "^1.4.0",
    "@eslint/js": "^9.13.0",
    "@types/bcryptjs": "^2.4.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.9",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.19.11",
    "@types/redlock": "^4.0.7",
    "@types/sharp": "^0.31.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.7",
    "@types/uuid": "^10.0.0",
    "@types/yamljs": "^0.2.34",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "cross-env": "^7.0.3",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^15.11.0",
    "prettier": "^3.8.1",
    "tsc-alias": "^1.8.14",
    "tsconfig-paths": "^3.9.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.12.2"
  },
  "dependencies": {
    "@types/web-push": "^3.6.4",
    "bcryptjs": "^2.4.3",
    "celebrate": "^15.0.1",
    "class-transformer": "^0.5.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.5.0",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.2.3",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.16.0",
    "pg": "^8.15.6",
    "reflect-metadata": "^0.1.13",
    "sharp": "^0.34.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tsyringe": "^4.8.0",
    "typeorm": "^0.3.17",
    "web-push": "^3.6.7",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "yamljs": "^0.3.0"
  }
}
